# Database Configuration
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=conecta_cidades
MYSQL_USER=conecta
MYSQL_PASSWORD=conecta_password
MYSQL_PORT=3306

# Application Configuration
APP_PORT=3000
NODE_ENV=production

# Database URL (automatically constructed from above variables)
DATABASE_URL=mysql://conecta:conecta_password@localhost:3306/conecta_cidades

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=change_this_secret_in_production_use_long_random_string

# Manus OAuth Configuration (Optional - for authentication features)
VITE_APP_ID=conecta-cidades
VITE_APP_TITLE=Conecta Cidades - Extrator de Dados Municipais
VITE_APP_LOGO=
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
OWNER_OPEN_ID=
OWNER_NAME=Admin

# Manus API Configuration (Optional - for advanced features)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Analytics Configuration (Optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
